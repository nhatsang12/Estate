# Runtime
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/estate_platform
DB_SERVER_SELECTION_TIMEOUT_MS=10000
DB_RETRY_DELAY_MS=5000
DB_MAX_RETRIES=0
SHUTDOWN_FORCE_TIMEOUT_MS=8000

# Auth
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret
JWT_REFRESH_EXPIRES_IN=90d

# API rate limit
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=2000

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# KYC service
KYC_PYTHON_SERVICE_URL=http://localhost:8001/process
KYC_PYTHON_FACE_COMPARE_URL=http://localhost:8001/compare-face
KYC_HTTP_TIMEOUT_MS=120000
KYC_HTTP_RETRY_ON_TIMEOUT=true
KYC_MATCH_THRESHOLD=0.88
KYC_ADDRESS_MATCH_THRESHOLD=0.7
KYC_OCR_CONFIDENCE_THRESHOLD=0.6
KYC_FACE_MATCH_THRESHOLD=0.65
KYC_FACE_MATCH_HARD_FLOOR=0.65

# Chatbot and embeddings
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004
GEMINI_EMBED_MODELS=text-embedding-004
CHATBOT_KB_DIR=
CHATBOT_SUMMARY_EVERY_TURNS=6
CHATBOT_RECENT_MEMORY_LIMIT=20
CHATBOT_RECENT_AFTER_SUMMARY=10
CHATBOT_SESSION_TTL_MINUTES=30
CHATBOT_EXPOSE_SKILL_OVERLAY=false

# Mongo Atlas search and vector settings
MONGO_SEARCH_INDEX=property_search
MONGO_VECTOR_INDEX=properties_vector_index
MONGO_VECTOR_PATH=embedding
MONGO_VECTOR_DIMENSIONS=768

# Payment URLs (frontend)
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_FAILED_URL=http://localhost:3000/payment/failed
PAYMENT_CANCELLED_URL=http://localhost:3000/payment/cancelled
PAYMENT_ERROR_URL=http://localhost:3000/payment/error

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_HTTP_TIMEOUT_MS=20000
PAYPAL_RETURN_URL=http://localhost:5000/api/payments/paypal_return
PAYPAL_CANCEL_URL=http://localhost:5000/api/payments/paypal_return

# VNPay
VNPAY_LOCALE=vn
VNPAY_TMNCODE=
VNPAY_HASHSECRET=
VNPAY_URL=
VNPAY_RETURN_URL=http://localhost:5000/api/payments/vnpay_return
VNPAY_EXPIRE_MINUTES=15
VNPAY_DEBUG=false

# Subscription bot
SUBSCRIPTION_REMINDER_DAYS=7
SUBSCRIPTION_REMINDER_CRON=0 9 * * *
SUBSCRIPTION_BOT_NAME=Subscription
SUBSCRIPTION_BOT_EMAIL=subscription@estatemanager.local
SUBSCRIPTION_BOT_PASSWORD=SubBot@change_me
SUBSCRIPTION_BOT_ADDRESS=System Automation
SUBSCRIPTION_BOT_PHONE=

# Pricing
PRICING_PRO_VNPAY_VND=19990000
PRICING_PRO_PAYPAL_USD=9.99
PRICING_PROPLUS_VNPAY_VND=99990000
PRICING_PROPLUS_PAYPAL_USD=19.99

# Jobs and scripts
TRANSACTION_CLEANUP_CRON=*/5 * * * *
PROPERTY_PRICE_ROUND_STEP=500000000
